/**
 * fillExpenses — ממלא הוצאות היסטוריות בטאב 📝 יומן הוצאות
 * מריץ פעם אחת בלבד — מחליף נתונים קיימים!
 */
function fillExpenses() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sh = ss.getSheetByName('📝 יומן הוצאות');
  if (!sh) { SpreadsheetApp.getUi().alert('לא נמצא'); return; }
  sh.getRange(5, 1, 2000, 13).clearContent();
  // ← הנתונים נמצאים בקובץ המקורי שנשמר בגיבוי
  SpreadsheetApp.getUi().alert('⚠️ הפונקציה הזו לא כוללת נתונים — השתמש בגיבוי המקורי');
}

/**
 * clearExpenses — מוחק את כל ההוצאות
 */
function clearExpenses() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sh = ss.getSheetByName('📝 יומן הוצאות');
  if (!sh) return;
  const ui = SpreadsheetApp.getUi();
  const resp = ui.alert('⚠️ אזהרה', 'למחוק את כל ההוצאות? פעולה זו אינה ניתנת לביטול.', ui.ButtonSet.YES_NO);
  if (resp !== ui.Button.YES) return;
  sh.getRange(5, 1, 5000, 13).clearContent();
  ui.alert('✅ נמחק הכל');
}
